            <ui:InvokeCode ContinueOnError="{x:Null}" sap2010:Annotation.AnnotationText="Add Borders in Excel" Code="Using wb As New ClosedXML.Excel.XLWorkbook(FilePath)&#xA;&#x9;&#x9;&#x9;For Each ws As ClosedXML.Excel.IXLWorksheet In wb.Worksheets&#xA;&#x9;&#x9;&#x9;&#x9;If CInt(ws.Name) &lt;= DaysToLoop Then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;' This will match &quot;Y&quot;, &quot;y&quot;, &quot;Yes&quot;, &quot;YES&quot;, etc.&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;If RangeDayMode.Equals(&quot;Y&quot;, StringComparison.OrdinalIgnoreCase) AndAlso (CInt(ws.Name) &lt;= CInt(StartDayValue) Or CInt(ws.Name) &gt;= CInt(EndDayValue)) Then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Continue For&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;End If&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;' Get the UsedRows (the number of rows to write end range)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;Dim UsedRows As Int32 = ws.RowsUsed.Count()&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;If UsedRows &gt; 3 Then&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;' UsedRows contains '- 3' because those are the extra values in row 1, 2 and 3 of excel&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;' UsedRow contains values including the starting row therefore added value is &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'3 instead Of 4 that is why 3 is used instead of starting at row 4&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Dim range = ws.Range(&quot;U4:W&quot; &amp; (3 + UsedRows - 3).ToString())&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;range.Style.Border.OutsideBorder = ClosedXML.Excel.XLBorderStyleValues.Thin&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;range.Style.Border.InsideBorder = ClosedXML.Excel.XLBorderStyleValues.Thin&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;End If&#xA;&#x9;&#x9;&#x9;&#x9;Else&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;Exit For&#xA;&#x9;&#x9;&#x9;&#x9;End If&#xA;&#x9;&#x9;&#x9;Next&#xA;&#x9;wb.Save()&#xA;End Using" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="416,219" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
